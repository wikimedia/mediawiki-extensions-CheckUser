{
	"root": true,
	"extends": [
		"wikimedia/client/common",
		"wikimedia/language/es2020",
		"wikimedia/jquery",
		"wikimedia/mediawiki",
		"wikimedia/qunit"
	],
	"globals": {
		"sinon": "readonly"
	},
	"env": {
		"browser": true
	},
	"rules": {
		"compat/compat": "off",
		"max-len": [ "warn", {
			"code": 120,
			"tabWidth": 4,
			"ignorePattern": "^[\\s]*(//|<!--) (es|style)lint-.+",
			"ignoreUrls": true,
			"ignoreComments": true,
			"ignoreRegExpLiterals": true,
			"ignoreStrings": true,
			"ignoreTemplateLiterals": true
		} ]
	}
}
